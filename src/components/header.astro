<header class="site-header">
  <nav class="nav-container">

  <button class="burger-menu" aria-label="Menu">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
    
    <div class="nav-section left">
      <a href="/nyheder">Nyheder</a>
      <a href="/specialoel">Specialøl</a>
      <a href="/smagskasser">Smagskasser</a>
    </div>

    <div class="logo">
      <a href="/">
        <img src="/logo(white).png" alt="A Good Case Logo" />
      </a>
    </div>

    <div class="nav-section right">
      <a href="/abonnementer">Abonnementer</a>
      <a href="/om-os">Om os</a>
      <a href="/erhverv">Erhverv</a>
      <button class="cart-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cart-icon"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>

</svg>
      </button>
    </div>




  <div class="mobile-nav">
    <button class="close-button"></button>
    <nav class="mobile-links"></nav>
    <a href="/nyheder">Nyheder</a>
    <a href="/specialoel">Specialøl</a>
    <a href="/smagskasser">Smagskasser</a>
    <a href="/abonnementer">Abonnementer</a>
    <a href="/om-os">Om os</a>
    <a href="/erhverv">Erhverv</a>

  </div>

  </nav>
</header>

<style>
  /* Selve den grønne bar */
  .site-header {
    background-color: #084734; /* Den mørkegrønne fra dit billede */
    padding: 0.75rem 0;
    color: white;
    width: 100%;
  }

  /* Containeren der holder styr på indholdet */
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px; /* Eller den bredde du har i Figma */
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Sektionerne (Venstre, Midte, Højre) */
  .nav-section {
    display: flex;
    gap: 2rem;
    flex: 1; /* Gør at venstre og højre fylder lige meget, så logoet bliver i midten */
  }

  .nav-section.right {
    justify-content: flex-end;
    align-items: center;
  }

  /* Styling af links */
  .nav-section a {
    color: white;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 300;
    transition: opacity 0.2s ease;
  }

  .nav-section a:hover {
    opacity: 0.7;
  }

  /* Logo styling */
  .logo img {
    height: 70px; /* Juster så det passer med dit logo */
    display: block;
  }

  /* Kurv-knappen */
  .cart-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 0;
    margin-left: 1rem;
  }

  .cart-icon {
    width: 24px;
    height: 24px;
  }

  .burger-menu, 
  .mobile-nav {
    display: none;
  }

@media (max-width: 768px) {

.nav-section.left,
.nav-section.right {
  display: none;
}

.nav-container {
  justify-content: center;
}

.burger-menu,
.nav-section.right {
  flex: 1;
}

.burger-menu {
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  padding: 0;
}

.bar {
  width: 35px;
  height: 5px;
  background: white;
  border-radius: 10px;
}

.logo {
  flex: 0;
  display: flex;
  justify-content: center;
}

.logo img {
  height: 60px;
}

.cart-btn {
  margin-left: 0;
}

.cart-icon {
  width: 30px;
  height: 30px;
}

.mobile-nav {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background-color: #084734;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  display: none;
}

.mobile-nav.is-open {
  display: flex;
}

}

</style>