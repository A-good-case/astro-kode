---
//@ts-nocheck
---
<header class="site-header">
  <nav class="nav-container">

  <button class="burger" aria-label="Menu">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
    
    <div class="nav-section left">
    <span class="desktop-links">
      <a href="/nyheder">Nyheder</a>
      <a href="/specialoel">Specialøl</a>
      <a href="/smagskasser">Smagskasser</a>
    </span>
    </div>

    <div class="logo">
      <a href="/">
        <img src="/logo(white).png" alt="A Good Case Logo" />
      </a>
    </div>

    <div class="nav-section right">
    <span class="desktop-links">
      <a href="/abonnementer">Abonnementer</a>
      <a href="/om-os">Om os</a>
      <a href="/erhverv">Erhverv</a>
    </span>


      <button class="cart-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cart-icon"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      </button>
    </div>

  </nav>

    <ul class="mobile-menu">
    <li><a href="/nyheder">Nyheder</a></li>
    <li><a href="/specialoel">Specialøl</a></li>
    <li><a href="/smagskasser">Smagskasser</a></li>
    <li><a href="/abonnementer">Abonnementer</a></li>
    <li><a href="/om-os">Om os</a></li>
    <li><a href="/erhverv">Erhverv</a></li>
    </ul>

</header>

<style>
  /* Selve den grønne bar */
  .site-header {
    background-color: #084734; /* Den mørkegrønne fra dit billede */
    padding: 0.75rem 0;
    color: white;
    width: 100%;
  }

  /* Containeren der holder styr på indholdet */
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px; /* Eller den bredde du har i Figma */
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Sektionerne (Venstre, Midte, Højre) */
  .nav-section {
    display: flex;
    gap: 2rem;
    flex: 1; /* Gør at venstre og højre fylder lige meget, så logoet bliver i midten */
  }

  .nav-section.right {
    justify-content: flex-end;
    align-items: center;
  }

  /* Styling af links */
  .nav-section a {
    color: white;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 300;
    transition: opacity 0.2s ease;
  }

  .nav-section a:hover {
    opacity: 0.7;
  }

  /* Logo styling */
  .logo img {
    height: 70px; /* Juster så det passer med dit logo */
    display: block;
  }

  /* Kurv-knappen */
  .cart-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 0;
    margin-left: 1rem;
  }

  .cart-icon {
    width: 24px;
    height: 24px;
  }

  .burger, 
  .mobile-menu {
    display: none;
  }

  .desktop-links  {
  display: flex;
  gap: 6.5rem;
  align-items: center;
  }


@media (max-width: 768px) {

.desktop-links {
  display: none;
}

.burger {
display: flex;
flex-direction:column;
gap: 6px;
background: none;
border: none;
cursor: pointer;
}

.bar {
  width: 35px;
  height: 5px;
  background: white;
  border-radius: 10px;
}


.nav-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 1.5rem;
}

.logo {
  margin-right: 2rem;
}


.nav-section.right {
  flex: 1;
  display: flex;
  ustify-content: flex-end;
}

.mobile-menu {
display: none;
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100vh;
background-color: #084734;
z-index: 1000;
flex-direction: column;
justify-content: center;
align-items: center;
list-style: none;
padding: 0;
margin: 0;
gap: 2rem;
}

.mobile-menu.open {
display: flex;
}

.mobile-menu a {
color: white;
text-decoration: none;
font-size: 32px;
}

.burger-menu {
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  padding: 0;
}

.mobile-menu li {
  margin: 1.5 rem 0;
}

.logo, 
.burger {
    position: relative;
    z-index: 2000; 
  }

  .nav-container.active +
  .mobile-menu {
    display: flex;
  }
  
  .mobile-menu li {
    margin: 1rem 0;
  }

}
</style>


<script>
  const burger = document.querySelector(".burger");
  const nav = document.querySelector(".nav-container");

  // Vi tjekker om elementerne findes før vi tilføjer event listeners
  if (burger && nav) {
    burger.addEventListener("click", () => {
      burger.classList.toggle("active");
      nav.classList.toggle("active");
      document.body.style.overflow = nav.classList.contains("active") ? "hidden" : "auto";
    });
  }
</script>