---
import Button from './button.astro';
import ProductCard from './ProductCard.astro'; // Vi genbruger din komponent!

const endpoint = "https://iwbvbapklibbvvbvkycl.supabase.co/rest/v1/a-good-case?select=*";
const options = {
    headers: {
        apikey: "sb_publishable_a_arvnmYGQIdHssKGJ0i8A_ggJVCbCi"
    }
}

// 1. Hent alle data
const data = await fetch(endpoint, options).then((response) => response.json());

// 2. Skær listen ned til de første 3 (Månedens udvalgte)
const udvalgte = data.slice(0, 3);
---

<section class="featured">
  <div class="container">
    <h2>Månedens udvalgte</h2>

    <div class="product-grid">
      {udvalgte.map((product: any) => (
        <ProductCard
          navn={product.name}
          bryggeri={product.category}
          pris={product.price}
          billede_url={product.image}
        />
      ))}
    </div>

    <div class="button-container">
      <Button text="Se hele udvalget" link="/productlist" />
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    padding: 60px 20px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); 
    gap: 20px;
    margin-bottom: 40px;
  }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 5rem;
    font-weight: 400;
    letter-spacing: 2px;  /* Giver lidt luft mellem de store bogstaver */
    text-transform: uppercase;}

@media (max-width: 768px) {
  
.product-grid {
  grid-template-columns: 1fr;
  padding: 0 20px;
}

h2 {
  font-size: 25px;
  text-align: center;
}

.button-container {
  margin-top: 60px;
  margin-bottom: 60px;
}

}

</style>
