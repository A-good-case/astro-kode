---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/button.astro';
export async function getStaticPaths() {
    
  const endpoint = "https://iwbvbapklibbvvbvkycl.supabase.co/rest/v1/a-good-case?select=*";

  const options = {
    headers: {
      apikey: "sb_publishable_a_arvnmYGQIdHssKGJ0i8A_ggJVCbCi"
    }
  };

  const response = await fetch(endpoint, options);
  const data = await response.json();

  return data.map((product: any) => {
    return {
      params: { id: product.id.toString() },
      props: { product },
    };
  });
}
 
const { product } = Astro.props as any;
---


<Layout>
<section class="product-details">

  <a href="/productlist" class="back">← Tilbage</a>

  <div class="container">

    <div class="image">
      <img src={product.image} alt={product.name} />
    </div>

    <div class="info">
      <h1>{product.name}</h1>
      <p class="category">{product.category}</p>
      <p class="price">{product.price} kr</p>
      <p class="reason">Årsag: Kosmetisk fejl</p>

      <div class="options">
        <label><input type="radio" /> 1.stk</label>
        <label><input type="radio" /> 6.stk</label>
      </div>

      <div class="quantity">
        <button>+</button>
        <span>1</span>
        <button>-</button>
      </div>

        <Button text="Læg i kurv" />
    </div>

  </div>

</section>
</Layout>


<style>
    h1 {
        font-family: sans-serif;
        font-size: 2.5rem;
        margin-bottom: 20px;
    }
    
    p {
        font-size: 1.2rem;
        margin-bottom: 10px;
    }
    
    img {
        max-width: 400px;
        margin-top: 20px;
    }

    